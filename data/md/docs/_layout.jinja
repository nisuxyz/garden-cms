          </li>
          <li>
            <a href="/docs/content-blocks" {% if title == "Content Blocks" %}aria-current="page"{% endif %}>Content Blocks</a>
          </li>
          <li>
            <a href="/docs/collections" {% if title == "Collections" %}aria-current="page"{% endif %}>Collections</a>
          </li>
          <li>
            <a href="/docs/themes" {% if title == "Themes" %}aria-current="page"{% endif %}>Themes</a>
          </li>
          <li>
            <a href="/docs/media" {% if title == "Media" %}aria-current="page"{% endif %}>Media</a>
          </li>
          <li>
            <a href="/docs/markdown-mounts" {% if title == "Markdown Mounts" %}aria-current="page"{% endif %}>Markdown Mounts</a>
          </li>
          <li>
            <a href="/docs/templates" {% if title == "Templates" %}aria-current="page"{% endif %}>Templates</a>
          </li>
          <li>
            <a href="/docs/authentication" {% if title == "Authentication" %}aria-current="page"{% endif %}>Authentication</a>
          </li>
          <li>
            <a href="/docs/deployment" {% if title == "Deployment" %}aria-current="page"{% endif %}>Deployment</a>
          </li>
          <li>
            <a href="/docs/configuration" {% if title == "Configuration" %}aria-current="page"{% endif %}>Configuration</a>
          </li>
        </ul>
      </details>
        <hr/>
    </nav>

    {{ content }}
  </article>
  <aside class="sticky-top">
    <span class="crumbs">
