<style>
  /* Two-column admin layout */
  #docs-main {
    display: grid;
    grid-template-columns: 12rem minmax(0, 1fr);
    gap: 2rem;
    align-items: start;
  }

  #docs-main > article {
    min-width: 0;
  }

  /* Keep desktop order as sidebar (left) + content (right). */
  #docs-main > aside {
    order: -1;
  }

  /* Sidebar */
  aside nav ul {
    list-style: none;
    padding: 0;
  }
  aside nav li {
    margin-bottom: 0.25rem;
  }
  aside nav a,
  aside form button {
    all: unset;
    display: block;
    padding: 0.4rem 0.75rem;
    border-radius: var(--pico-border-radius);
    font-size: 0.9rem;
    cursor: pointer;
  }
  aside nav a:hover,
  aside form button:hover {
    background: var(--pico-card-background-color);
  }
  aside form {
    margin: 0;
  }

  #docs-main .crumbs {
    font-size: 0.85rem;
    margin-bottom: 2rem;
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Desktop: keep only the sidebar breadcrumb indicator. */
  #docs-main > article > .crumbs {
    display: none;
  }

  .docs-mobile-nav {
    display: none;
  }

  .docs-mobile-nav details {
    margin: 0 0 1rem;
  }

  .docs-mobile-nav summary {
    font-size: 0.95rem;
    font-weight: 600;
  }

  .docs-mobile-nav ul {
    list-style: none;
    padding: 0;
    margin: 0.75rem 0 0;
    max-height: 50vh;
    overflow: auto;
  }

  .docs-mobile-nav li {
    margin-bottom: 0.25rem;
  }

  .docs-mobile-nav a {
    display: block;
    padding: 0.4rem 0.6rem;
    border-radius: var(--pico-border-radius);
    text-decoration: none;
  }

  .docs-mobile-nav a[aria-current="page"] {
    background: var(--pico-card-sectioning-background-color);
    font-weight: 600;
  }

  @media (max-width: 768px) {
    #docs-main {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
    #docs-main > aside {
      display: none;
    }
    #docs-main .crumbs {
      justify-content: flex-start;
      margin-bottom: 1rem;
      gap: 0.5rem;
    }
    #docs-main > article > .crumbs {
      display: flex;
    }
    .docs-mobile-nav {
      display: block;
    }
  }
</style>
<main id="docs-main">
  <article>
    <span class="crumbs">
      <a href="/docs">Docs</a>
      &rsaquo;
      <strong>{{ title }}</strong>
    </span>

    <nav class="docs-mobile-nav" aria-label="Docs sections">
        <hr/>
      <details {% if title == "Docs" %}open{% endif %}>
        <summary>Topics</summary>
        <ul>
          <li>
